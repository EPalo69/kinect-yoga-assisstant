<Window x:Class="YAMAS.Views.SessionResultsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Session Results" Height="800" Width="1200"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#0A0F1E"
        WindowStyle="None"
        AllowsTransparency="True">

    <Grid>
        <!-- Overlay Canvas for Hand Cursor -->
        <Canvas x:Name="CursorCanvas" IsHitTestVisible="False" Panel.ZIndex="100"/>

        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/> <!-- Practice Again & New Pose Button -->
                <ColumnDefinition Width="Auto"/> <!-- Details -->
                <ColumnDefinition Width="Auto"/> <!-- Main Menu Button -->
            </Grid.ColumnDefinitions>

            <!-- Left: New Pose & Practice Again -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,60,0">
                <!-- Top: New Pose -->
                <Grid x:Name="NewPoseButton" Width="200" Height="200"
                      HorizontalAlignment="Center" Margin="0,0,0,40"
                      Cursor="Hand" MouseLeftButtonUp="NewPose_Click">
                    <Ellipse Stroke="#A855F7" StrokeThickness="2" Fill="#111827"/>
                    <Ellipse x:Name="Progress_NewPose" Stroke="#A855F7" StrokeThickness="4" Fill="Transparent" 
                             StrokeDashArray="0,628" StrokeDashOffset="-1" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform><RotateTransform Angle="-90"/></Ellipse.RenderTransform>
                    </Ellipse>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="✦" FontSize="52" Foreground="#A855F7" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="New Pose" FontSize="20" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Bottom: Practice Again -->
                <Grid x:Name="PracticeAgainButton" Width="200" Height="200"
                      HorizontalAlignment="Center"
                      Cursor="Hand" MouseLeftButtonUp="PracticeAgain_Click">
                    <Ellipse Stroke="#4DD0E1" StrokeThickness="2" Fill="#111827"/>
                    <Ellipse x:Name="Progress_Practice" Stroke="#4DD0E1" StrokeThickness="4" Fill="Transparent" 
                             StrokeDashArray="0,628" StrokeDashOffset="-1" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform><RotateTransform Angle="-90"/></Ellipse.RenderTransform>
                    </Ellipse>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="↺" FontSize="56" Foreground="#4DD0E1" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="Practice Again" FontSize="20" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Right: Main Menu -->
            <Grid x:Name="MainMenuButton" Grid.Column="2" Width="200" Height="200"
                  HorizontalAlignment="Center" VerticalAlignment="Center" Margin="60,0,0,0"
                  Cursor="Hand" MouseLeftButtonUp="MainMenu_Click">
                <Ellipse Stroke="#EF4444" StrokeThickness="2" Fill="#111827"/>
                <Ellipse x:Name="Progress_MainMenu" Stroke="#EF4444" StrokeThickness="4" Fill="Transparent" 
                         StrokeDashArray="0,628" StrokeDashOffset="-1" RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform><RotateTransform Angle="-90"/></Ellipse.RenderTransform>
                </Ellipse>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="⌂" FontSize="52" Foreground="#EF4444" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Main Menu" FontSize="20" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Center: Results Details -->
            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="600">
                <!-- Trophy / result icon -->
                <TextBlock x:Name="ResultIcon" Text="🏆"
                           FontSize="80" HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>

                <TextBlock Text="SESSION COMPLETE"
                           FontSize="14" FontWeight="Bold"
                           Foreground="#4DD0E1"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>

                <TextBlock x:Name="PoseNameLabel"
                           Text="Mountain Pose"
                           FontSize="36" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32"/>

                <!-- Score ring -->
                <Border Background="#111827" CornerRadius="100"
                        Width="200" Height="200"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,32">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="AccuracyLabel"
                                   Text="0%"
                                   FontSize="52" FontWeight="Bold"
                                   Foreground="#4DD0E1"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="ACCURACY"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="#6B7280"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Stats row -->
                <Grid Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#111827" CornerRadius="10" Padding="16" Margin="0,0,6,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="SESSION TIME" FontSize="10" FontWeight="Bold" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TotalTimeLabel" Text="00:00" FontSize="24" FontWeight="Bold" Foreground="#22C55E" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#111827" CornerRadius="10" Padding="16" Margin="6,0,6,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="HOLD TIME" FontSize="10" FontWeight="Bold" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock x:Name="HoldTimeLabel" Text="0s" FontSize="24" FontWeight="Bold" Foreground="#22C55E" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#111827" CornerRadius="10" Padding="16" Margin="6,0,6,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="BEST SCORE" FontSize="10" FontWeight="Bold" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock x:Name="BestScoreLabel" Text="0%" FontSize="24" FontWeight="Bold" Foreground="#F59E0B" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Background="#111827" CornerRadius="10" Padding="16" Margin="6,0,0,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="DIFFICULTY" FontSize="10" FontWeight="Bold" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock x:Name="DifficultyLabel" Text="Beginner" FontSize="18" FontWeight="Bold" Foreground="#A855F7" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Feedback message -->
                <Border Background="#111827" CornerRadius="10" Padding="20,14" Margin="0,0,0,0">
                    <TextBlock x:Name="FeedbackMessage" Text="Great job! Keep practicing to improve your form." FontSize="14" Foreground="#D1D5DB" TextAlignment="Center" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>