<Window x:Class="capstoneOneShot.Views.PoseDetailView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pose Detail" Height="800" Width="1200"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#0A0F1E">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <!-- Left: visual area -->
            <ColumnDefinition Width="420"/>
            <!-- Right: details -->
        </Grid.ColumnDefinitions>

        <!-- LEFT: Visual area -->
        <Border Grid.Column="0" Background="#0D0D1A"
                Margin="40,40,20,40" CornerRadius="16">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image x:Name="PoseImage"
                       Width="400" Height="400"
                       Stretch="UniformToFill"
                       HorizontalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                    <TextBlock Text="⏱ " Foreground="#4DD0E1" FontSize="20"/>
                    <TextBlock x:Name="HoldTimeLeftLabel"
                               Text="20s hold"
                               FontSize="20" FontWeight="Bold" Foreground="#9CA3AF"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- RIGHT: Details panel -->
        <Border Grid.Column="1" Background="#111827"
                Margin="20,40,40,40" CornerRadius="16" Padding="32">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Back -->
                <Grid Grid.Row="0" x:Name="Btn_Back" Width="100" Height="100" Cursor="Hand" Tag="Back"
                      HorizontalAlignment="Center" Margin="0,0,0,24"
                      MouseLeftButtonUp="BackButton_Click">
                    <Ellipse x:Name="Glow_Back" Fill="#006B7280" Opacity="0"/>
                    <Ellipse Stroke="#6B7280" StrokeThickness="2" Fill="#111827"/>
                    <Ellipse x:Name="Progress_Back" Stroke="#6B7280" StrokeThickness="4" Fill="Transparent" StrokeDashArray="0,314" StrokeDashOffset="-1" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform><RotateTransform Angle="-90"/></Ellipse.RenderTransform>
                    </Ellipse>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="←" FontSize="20" Foreground="#6B7280" HorizontalAlignment="Center"/>
                        <TextBlock Text="Back" FontSize="11" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Steps (defaults to be overwritten by .cs) -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="RulesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0D0D1A" CornerRadius="8"
                                        Padding="14,10" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="→ " Foreground="#4DD0E1"
                                                   FontSize="13" FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Feedback}"
                                                   FontSize="13" Foreground="#D1D5DB"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                        <!-- Fallback defaults -->
                        <Border Background="#0D0D1A" CornerRadius="8" Padding="14,10" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="→ " Foreground="#4DD0E1" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="Default Step 1: Stand in position" FontSize="13" Foreground="#D1D5DB" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#0D0D1A" CornerRadius="8" Padding="14,10" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="→ " Foreground="#4DD0E1" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="Default Step 2: Keep arms extended" FontSize="13" Foreground="#D1D5DB" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Begin button -->
                <Grid Grid.Row="2" x:Name="Btn_Begin" Width="150" Height="150" Cursor="Hand" Tag="Begin"
                      HorizontalAlignment="Center" Margin="0,24,0,0"
                      MouseLeftButtonUp="BeginButton_Click">
                    <Ellipse x:Name="Glow_Begin" Fill="#004DD0E1" Opacity="0"/>
                    <Ellipse Stroke="#4DD0E1" StrokeThickness="2" Fill="#111827"/>
                    <Ellipse x:Name="Progress_Begin" Stroke="#4DD0E1" StrokeThickness="4" Fill="Transparent" StrokeDashArray="0,471" StrokeDashOffset="-1" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform><RotateTransform Angle="-90"/></Ellipse.RenderTransform>
                    </Ellipse>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="▶" FontSize="28" Foreground="#4DD0E1" HorizontalAlignment="Center"/>
                        <TextBlock Text="Begin" FontSize="13" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBlock Text="Session" FontSize="13" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</Window>