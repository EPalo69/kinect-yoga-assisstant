<Window x:Class="capstoneOneShot.Views.PoseDetailView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pose Detail" Height="800" Width="1200"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#0A0F1E">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <!-- Left: visual area -->
            <ColumnDefinition Width="420"/>
            <!-- Right: details -->
        </Grid.ColumnDefinitions>

        <!-- LEFT: Placeholder for pose illustration -->
        <Border Grid.Column="0" Background="#0D0D1A"
                Margin="40,40,20,40" CornerRadius="16">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="PoseIconLabel"
                           Text="🧘"
                           FontSize="100"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="PoseNameBig"
                           Text="Mountain Pose"
                           FontSize="28" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"/>
                <TextBlock Text="Illustration / Avatar will appear here during session"
                           FontSize="13" Foreground="#374151"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"/>
            </StackPanel>
        </Border>

        <!-- RIGHT: Details panel -->
        <Border Grid.Column="1" Background="#111827"
                Margin="20,40,40,40" CornerRadius="16" Padding="32">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Back -->
                    <Button x:Name="BackButton" Content="← Back to Poses"
                            Background="Transparent" Foreground="#6B7280"
                            FontSize="13" BorderThickness="0"
                            HorizontalAlignment="Left" Cursor="Hand"
                            Click="BackButton_Click" Margin="0,0,0,24"/>

                    <!-- Difficulty badge -->
                    <Border x:Name="DifficultyBadge" Background="#1F2937"
                            CornerRadius="20" Padding="12,5"
                            HorizontalAlignment="Left" Margin="0,0,0,16">
                        <TextBlock x:Name="DifficultyLabel"
                                   Text="Beginner"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="#4DD0E1"/>
                    </Border>

                    <!-- Pose name -->
                    <TextBlock x:Name="PoseNameLabel"
                               Text="Mountain Pose"
                               FontSize="28" FontWeight="Bold"
                               Foreground="White"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <!-- Description -->
                    <TextBlock x:Name="DescriptionLabel"
                               Text=""
                               FontSize="14" Foreground="#9CA3AF"
                               TextWrapping="Wrap" LineHeight="24"
                               Margin="0,0,0,28"/>

                    <Separator Background="#1F2937" Margin="0,0,0,24"/>

                    <!-- Stats row -->
                    <Grid Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#0D0D1A"
                                CornerRadius="10" Padding="16" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="HOLD TIME" FontSize="10"
                                           FontWeight="Bold" Foreground="#6B7280"
                                           Margin="0,0,0,6"/>
                                <TextBlock x:Name="HoldTimeLabel"
                                           Text="20s"
                                           FontSize="28" FontWeight="Bold"
                                           Foreground="#4DD0E1"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#0D0D1A"
                                CornerRadius="10" Padding="16" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="JOINTS TRACKED" FontSize="10"
                                           FontWeight="Bold" Foreground="#6B7280"
                                           Margin="0,0,0,6"/>
                                <TextBlock x:Name="JointCountLabel"
                                           Text="4"
                                           FontSize="28" FontWeight="Bold"
                                           Foreground="#A855F7"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Separator Background="#1F2937" Margin="0,0,0,24"/>

                    <!-- How to perform -->
                    <TextBlock Text="HOW TO PERFORM"
                               FontSize="11" FontWeight="Bold"
                               Foreground="#6B7280" Margin="0,0,0,12"/>

                    <!-- Joint rules list -->
                    <ItemsControl x:Name="RulesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0D0D1A" CornerRadius="8"
                                        Padding="14,10" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="→ " Foreground="#4DD0E1"
                                                   FontSize="13" FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Feedback}"
                                                   FontSize="13" Foreground="#D1D5DB"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Background="#1F2937" Margin="0,24,0,24"/>

                    <!-- Begin button -->
                    <Button x:Name="BeginButton"
                            Content="Begin Session"
                            FontSize="17" FontWeight="Bold"
                            Foreground="White" BorderThickness="0"
                            Padding="0,16" Cursor="Hand"
                            Click="BeginButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#4DD0E1" CornerRadius="10"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>