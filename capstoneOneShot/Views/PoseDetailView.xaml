<Window x:Class="capstoneOneShot.Views.PoseDetailView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pose Detail"
        Height="900" Width="1400"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#080D1A"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <!-- Gradient accent brush -->
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#4DD0E1" Offset="0"/>
            <GradientStop Color="#7C3AED" Offset="1"/>
        </LinearGradientBrush>

        <!-- Step item style -->
        <Style x:Key="StepItem" TargetType="Border">
            <Setter Property="Background" Value="#0F1525"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <!-- Root grid: status bar + top content + bottom footer -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>  <!-- Status bar -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Status pill bar ── -->
        <Border Grid.Row="0"
                Background="#0A0F1E"
                BorderBrush="#194DD0E1"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Margin="0,0,20,0">
                <Border Background="#111827" CornerRadius="20" Padding="12,4" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="PillKinectDot" Width="7" Height="7" Fill="#EF4444"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="PillKinectLabel" Text="Kinect Not Connected"
                                   Foreground="#9CA3AF" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Border Background="#111827" CornerRadius="20" Padding="12,4" Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="PillBodyDot" Width="7" Height="7" Fill="#EF4444"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="PillBodyLabel" Text="No Body Detected"
                                   Foreground="#9CA3AF" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Border Background="#111827" CornerRadius="20" Padding="12,4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="PillROMDot" Width="7" Height="7" Fill="#EF4444"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="PillROMLabel" Text="ROM Not Loaded"
                                   Foreground="#9CA3AF" FontSize="11"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ── Main content row ── -->
        <Grid Grid.Row="1" Margin="40,36,40,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>  <!-- Left: image panel -->
                <ColumnDefinition Width="32"/>  <!-- Gutter -->
                <ColumnDefinition Width="7*"/>  <!-- Right: details -->
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════════════════════════
                 LEFT — Pose Image Card
                 ══════════════════════════════════════════════════════════ -->
            <Border Grid.Column="0"
                    CornerRadius="20"
                    ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0D1225" Offset="0"/>
                        <GradientStop Color="#111830" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E2D4A" Offset="0"/>
                        <GradientStop Color="#2A1A4A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>1</Border.BorderThickness>

                <Grid>
                    <!-- Subtle radial glow behind image -->
                    <Ellipse HorizontalAlignment="Center" VerticalAlignment="Center"
                             Width="380" Height="380">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#1A4DD0E1" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Pose image -->
                        <Border CornerRadius="12" ClipToBounds="True"
                                HorizontalAlignment="Center"
                                Width="340" Height="340">
                            <Image x:Name="PoseImage"
                                   Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>

                        <!-- Hold-time badge -->
                        <Border HorizontalAlignment="Center" Margin="0,20,0,0"
                                Background="#0A1628" CornerRadius="24"
                                Padding="20,8" BorderThickness="1">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#4DD0E1" Offset="0"/>
                                    <GradientStop Color="#7C3AED" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="⏱" Foreground="#4DD0E1" FontSize="18"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock x:Name="HoldTimeLabel"
                                           FontSize="15" FontWeight="Bold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#4DD0E1" Offset="0"/>
                                            <GradientStop Color="#C4B5FD" Offset="1"/>
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════════
                 RIGHT — Details panel
                 ══════════════════════════════════════════════════════════ -->
            <Border Grid.Column="2" CornerRadius="20" Padding="36,32,36,28">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0D1225" Offset="0"/>
                        <GradientStop Color="#111830" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E2D4A" Offset="0"/>
                        <GradientStop Color="#2A1A4A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>1</Border.BorderThickness>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Header block -->
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>  <!-- Brief info -->
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>  <!-- Description -->
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="*"/>     <!-- Instructions list -->
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="Auto"/>  <!-- Proceed button -->
                    </Grid.RowDefinitions>

                    <!-- ── Header: pose name + difficulty badge ── -->
                    <StackPanel Grid.Row="0">
                        <!-- Thin accent line -->
                        <Border Height="3" Width="60" HorizontalAlignment="Left"
                                CornerRadius="2" Margin="0,0,0,10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#4DD0E1" Offset="0"/>
                                    <GradientStop Color="#7C3AED" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <DockPanel>
                            <TextBlock x:Name="PoseNameLabel"
                                       FontSize="32" FontWeight="Bold"
                                       Foreground="White"
                                       DockPanel.Dock="Left"
                                       VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#4DD0E1" BlurRadius="18" ShadowDepth="0" Opacity="0.35"/>
                                </TextBlock.Effect>
                            </TextBlock>

                            <!-- Difficulty badge -->
                            <Border x:Name="DifficultyBadge"
                                    DockPanel.Dock="Right"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    CornerRadius="12" Padding="14,5">
                                <TextBlock x:Name="DifficultyLabel"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="White"/>
                            </Border>
                        </DockPanel>
                    </StackPanel>

                    <!-- ── Brief info tagline ── -->
                    <TextBlock Grid.Row="2"
                               x:Name="BriefInfoLabel"
                               FontSize="14" FontStyle="Italic"
                               Foreground="#9CA3AF"
                               TextWrapping="Wrap"
                               LineHeight="22"/>

                    <!-- ── Description ── -->
                    <Border Grid.Row="4"
                            Background="#080E1E" CornerRadius="10" Padding="14,10">
                        <TextBlock x:Name="DescriptionLabel"
                                   FontSize="13" Foreground="#CBD5E1"
                                   TextWrapping="Wrap" LineHeight="21"/>
                    </Border>

                    <!-- ── Step-by-step instructions ── -->
                    <StackPanel Grid.Row="6">
                        <TextBlock Text="HOW TO PERFORM"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#4DD0E1" Margin="0,0,0,10"/>
                        <ItemsControl x:Name="InstructionsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource StepItem}">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="#1A4DD0E1" CornerRadius="10"
                                                    Width="22" Height="22" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding Number}"
                                                           FontSize="11" FontWeight="Bold"
                                                           Foreground="#4DD0E1"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding Text}"
                                                       FontSize="12.5" Foreground="#D1D5DB"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center"
                                                       MaxWidth="480"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- ── Proceed button (hover-timer) ── -->
                    <Grid Grid.Row="8"
                          x:Name="Btn_Proceed"
                          Width="150" Height="150"
                          Cursor="Hand" Tag="Proceed"
                          HorizontalAlignment="Center">
                        <Ellipse x:Name="Glow_Proceed">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#604DD0E1" Offset="0"/>
                                    <GradientStop Color="#00000000" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Opacity>0</Ellipse.Opacity>
                        </Ellipse>
                        <!-- Base ring -->
                        <Ellipse Stroke="#1E3A4A" StrokeThickness="2">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0D1828" Offset="0"/>
                                    <GradientStop Color="#111E30" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <!-- Progress arc -->
                        <Ellipse x:Name="Progress_Proceed"
                                 StrokeThickness="4"
                                 Fill="Transparent"
                                 StrokeDashArray="0,471"
                                 StrokeDashOffset="-1"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.Stroke>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#4DD0E1" Offset="0"/>
                                    <GradientStop Color="#7C3AED" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Stroke>
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="-90"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <!-- Label -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="▶" FontSize="30" HorizontalAlignment="Center">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#4DD0E1" Offset="0"/>
                                        <GradientStop Color="#7C3AED" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                            <TextBlock Text="Proceed" FontSize="13" FontWeight="SemiBold"
                                       Foreground="White" HorizontalAlignment="Center"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>

                </Grid>
            </Border>

        </Grid><!-- end main content grid -->

        <!-- ── Skeleton / Pointer overlays (full-window, above all content) ── -->
        <Canvas x:Name="SkeletonCanvas" Grid.Row="0" Grid.RowSpan="3"
                Panel.ZIndex="10" IsHitTestVisible="False"/>
        <Canvas x:Name="MenuCanvas" Grid.Row="0" Grid.RowSpan="3"
                Panel.ZIndex="20" IsHitTestVisible="False"/>

        <!-- ── Footer hint ── -->
        <TextBlock Grid.Row="2"
                   Text="Auto-proceeds in 8s  •  Hover over Proceed to speed up"
                   Foreground="#2D3748" FontSize="12"
                   HorizontalAlignment="Center"
                   Margin="0,6,0,16"/>

    </Grid>
</Window>