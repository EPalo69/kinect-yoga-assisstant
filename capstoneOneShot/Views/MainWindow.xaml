<Window x:Class="capstoneOneShot.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YAMAS" Height="800" Width="1200"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#0A0F1E"
        WindowStyle="None"
        AllowsTransparency="True">
    <!-- :helix="http://helix-toolkit.org/wpf" -->

    <!-- Root Grid: no RowDefinitions so all children stack in same cell -->
    <Grid>

        <!-- LAYER 1: UI Layout -->
        <Grid x:Name="UILayer">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Title + pills -->
                <RowDefinition Height="*"/>
                <!-- Buttons -->
                <RowDefinition Height="Auto"/>
                <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Title + pills -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,48,0,0">
                <TextBlock Text="YAMAS" FontSize="52" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="KINECT YOGA ASSISTANT" FontSize="14" FontWeight="Light"
                           Foreground="#4DD0E1" HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            Margin="0,20,0,0">
                    <Border Background="#111827" CornerRadius="20"
                            Padding="16,6" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="KinectStatusDot" Width="8" Height="8"
                                     Fill="#EF4444" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="KinectStatusLabel" Text="Kinect Not Connected"
                                       Foreground="#9CA3AF" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#111827" CornerRadius="20" Padding="16,6" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="BodyStatusDot" Width="8" Height="8"
                                     Fill="#EF4444" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="BodyStatusLabel" Text="No Body Detected"
                                       Foreground="#9CA3AF" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#111827" CornerRadius="20" Padding="16,6">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="ROMStatusDot" Width="8" Height="8"
                                     Fill="#EF4444" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="ROMStatusLabel" Text="ROM Not Loaded"
                                       Foreground="#9CA3AF" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- LAYER 1 ROW 1: Plain Canvas for buttons — never reflows -->
            <Canvas Grid.Row="1" x:Name="MenuCanvas"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">

                <Canvas x:Name="SkeletonCanvas" IsHitTestVisible="False"
                    Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Canvas}}"
                    Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}"
                    Panel.ZIndex="998"/>


                <!-- All buttons start at 0,0 — PlaceButtons() in code moves them -->

                <!-- Start Session -->
                <Grid x:Name="Btn_StartSession" Width="180" Height="180"
                      Cursor="Hand" Tag="StartSession">
                    <Ellipse x:Name="Glow_StartSession" Fill="#004DD0E1" Opacity="0"/>
                    <Ellipse Stroke="#4DD0E1" StrokeThickness="2" Fill="#111827"/>
                    <Ellipse x:Name="Progress_StartSession"
                             Stroke="#4DD0E1" StrokeThickness="4" Fill="Transparent"
                             StrokeDashArray="0,600" StrokeDashOffset="-1"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform Angle="-90"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="▶" FontSize="34" Foreground="#4DD0E1" HorizontalAlignment="Center"/>
                        <TextBlock Text="Start" FontSize="15" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBlock Text="Session" FontSize="15" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- ROM Test -->
                <Grid x:Name="Btn_ROMTest" Width="180" Height="180"
                      Cursor="Hand" Tag="ROMTest">
                    <Ellipse x:Name="Glow_ROMTest" Fill="#0022C55E" Opacity="0"/>
                    <Ellipse Stroke="#22C55E" StrokeThickness="2" Fill="#111827"/>
                    <Ellipse x:Name="Progress_ROMTest"
                             Stroke="#22C55E" StrokeThickness="4" Fill="Transparent"
                             StrokeDashArray="0,600" StrokeDashOffset="-1"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform Angle="-90"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="◎" FontSize="29" Foreground="#22C55E" HorizontalAlignment="Center"/>
                        <TextBlock Text="ROM" FontSize="14" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBlock Text="Test" FontSize="14" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Pose Library -->
                <Grid x:Name="Btn_PoseLibrary" Width="180" Height="180"
                      Cursor="Hand" Tag="PoseLibrary">
                    <Ellipse x:Name="Glow_PoseLibrary" Fill="#00A855F7" Opacity="0"/>
                    <Ellipse Stroke="#A855F7" StrokeThickness="2" Fill="#111827"/>
                    <Ellipse x:Name="Progress_PoseLibrary"
                             Stroke="#A855F7" StrokeThickness="4" Fill="Transparent"
                             StrokeDashArray="0,600" StrokeDashOffset="-1"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform Angle="-90"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="☰" FontSize="29" Foreground="#A855F7" HorizontalAlignment="Center"/>
                        <TextBlock Text="Pose" FontSize="14" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBlock Text="Library" FontSize="14" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Settings -->
                <Grid x:Name="Btn_Settings" Width="180" Height="180"
                      Cursor="Hand" Tag="Settings">
                    <Ellipse x:Name="Glow_Settings" Fill="#00F59E0B" Opacity="0"/>
                    <Ellipse Stroke="#F59E0B" StrokeThickness="2" Fill="#111827"/>
                    <Ellipse x:Name="Progress_Settings"
                             Stroke="#F59E0B" StrokeThickness="4" Fill="Transparent"
                             StrokeDashArray="0,600" StrokeDashOffset="-1"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform Angle="-90"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="⚙" FontSize="26" Foreground="#F59E0B" HorizontalAlignment="Center"/>
                        <TextBlock Text="Settings" FontSize="13" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Exit -->
                <Grid x:Name="Btn_Exit" Width="180" Height="180"
                      Cursor="Hand" Tag="Exit">
                    <Ellipse x:Name="Glow_Exit" Fill="#00EF4444" Opacity="0"/>
                    <Ellipse Stroke="#EF4444" StrokeThickness="2" Fill="#111827"/>
                    <Ellipse x:Name="Progress_Exit"
                             Stroke="#EF4444" StrokeThickness="4" Fill="Transparent"
                             StrokeDashArray="0,600" StrokeDashOffset="-1"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform Angle="-90"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="✕" FontSize="26" Foreground="#EF4444" HorizontalAlignment="Center"/>
                        <TextBlock Text="Exit" FontSize="13" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>

            </Canvas>

            <!-- Footer -->
            <TextBlock Grid.Row="2"
                       Text="Hover your hand over a button to select  •  Hold to confirm"
                       Foreground="#9CA3AF" FontSize="20"
                       HorizontalAlignment="Center" Margin="0,0,0,24"/>
        </Grid>

        <!-- LAYER 2: Avatar — same root Grid cell, zero layout influence
        <helix:HelixViewport3D x:Name="AvatarViewport"
                               IsHitTestVisible="False"
                               Background="Transparent"
                               ShowCoordinateSystem="False"
                               ShowViewCube="False"
                               Panel.ZIndex="999">
            <helix:HelixViewport3D.Camera>
                <PerspectiveCamera Position="0,1,4"
                                   LookDirection="0,-0.2,-1"
                                   UpDirection="0,1,0"
                                   FieldOfView="45"/>
            </helix:HelixViewport3D.Camera>

            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <AmbientLight Color="#AAAAAA"/>
                </ModelVisual3D.Content>
            </ModelVisual3D>

            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <DirectionalLight Color="White" Direction="0,-1,-1"/>
                </ModelVisual3D.Content>
            </ModelVisual3D>
        </helix:HelixViewport3D> -->

    </Grid>
</Window>