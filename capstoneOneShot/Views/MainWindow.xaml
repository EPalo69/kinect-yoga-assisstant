<Window x:Class="capstoneOneShot.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZenPose" Height="800" Width="1200"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#0A0F1E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Canvas x:Name="AvatarCanvas"
                Grid.RowSpan="3"
                IsHitTestVisible="False"/>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,48,0,0">
            <TextBlock Text="ZEN POSE"
                       FontSize="52" FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="YOGA ASSISTANT"
                       FontSize="14" FontWeight="Light"
                       Foreground="#4DD0E1"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>

            <!-- Status pills row -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,0">

                <!-- Kinect status -->
                <Border Background="#111827" CornerRadius="20"
                        Padding="16,6" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="KinectStatusDot" Width="8" Height="8"
                                 Fill="#EF4444" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="KinectStatusLabel" Text="Kinect Not Connected"
                                   Foreground="#9CA3AF" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Body detection status -->
                <Border Background="#111827" CornerRadius="20" Padding="16,6">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="BodyStatusDot" Width="8" Height="8"
                                 Fill="#EF4444" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="BodyStatusLabel" Text="No Body Detected"
                                   Foreground="#9CA3AF" FontSize="12"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </StackPanel>

        <!-- ── Triangle button layout ── -->
        <!-- ── Button Grid layout ── -->
        <Grid Grid.Row="1" x:Name="MenuGrid" VerticalAlignment="Top" Margin="0,20,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Row 1: Start Session (center) -->
            <Grid x:Name="Btn_StartSession"
          Grid.Row="0" Grid.Column="1"
          Margin="0,0,0,0"
          Width="150" Height="150"
          Cursor="Hand" Tag="StartSession">
                <Ellipse x:Name="Glow_StartSession" Fill="#004DD0E1" Opacity="0"/>
                <Ellipse Stroke="#4DD0E1" StrokeThickness="2" Fill="#111827"/>
                <Ellipse x:Name="Progress_StartSession" 
                 Stroke="#4DD0E1" StrokeThickness="4" Fill="Transparent"
                 StrokeDashArray="0,471" StrokeDashOffset="-1"
                 RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="-90"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="▶" FontSize="28" Foreground="#4DD0E1" HorizontalAlignment="Center"/>
                    <TextBlock Text="Start" FontSize="13" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    <TextBlock Text="Session" FontSize="13" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Row 2: ROM Test (left) -->
            <Grid x:Name="Btn_ROMTest"
          Grid.Row="1" Grid.Column="0"
          HorizontalAlignment="Right"
          Margin="0,-100,30,0"
          Width="150" Height="150"
          Cursor="Hand" Tag="ROMTest">
                <Ellipse x:Name="Glow_ROMTest" Fill="#0022C55E" Opacity="0"/>
                <Ellipse Stroke="#22C55E" StrokeThickness="2" Fill="#111827"/>
                <Ellipse x:Name="Progress_ROMTest"
                 Stroke="#22C55E" StrokeThickness="4" Fill="Transparent"
                 StrokeDashArray="0,471" StrokeDashOffset="-1"
                 RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="-90"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="◎" FontSize="24" Foreground="#22C55E" HorizontalAlignment="Center"/>
                    <TextBlock Text="ROM" FontSize="12" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    <TextBlock Text="Test" FontSize="12" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Row 2: Pose Library (right) -->
            <Grid x:Name="Btn_PoseLibrary"
          Grid.Row="1" Grid.Column="2"
          HorizontalAlignment="Left"
          Margin="30,-100,0,0"
          Width="150" Height="150"
          Cursor="Hand" Tag="PoseLibrary">
                <Ellipse x:Name="Glow_PoseLibrary" Fill="#00A855F7" Opacity="0"/>
                <Ellipse Stroke="#A855F7" StrokeThickness="2" Fill="#111827"/>
                <Ellipse x:Name="Progress_PoseLibrary"
                 Stroke="#A855F7" StrokeThickness="4" Fill="Transparent"
                 StrokeDashArray="0,471" StrokeDashOffset="-1"
                 RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="-90"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="☰" FontSize="24" Foreground="#A855F7" HorizontalAlignment="Center"/>
                    <TextBlock Text="Pose" FontSize="12" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    <TextBlock Text="Library" FontSize="12" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Row 3: Settings (left) -->
            <Grid x:Name="Btn_Settings"
                  Grid.Row="2" Grid.Column="0"
                  HorizontalAlignment="Right"
                  Margin="0,-80,200,0"
                  Width="150" Height="150"
                  Cursor="Hand" Tag="Settings">
                <Ellipse x:Name="Glow_Settings" Fill="#00F59E0B" Opacity="0"/>
                <Ellipse Stroke="#F59E0B" StrokeThickness="2" Fill="#111827"/>
                <Ellipse x:Name="Progress_Settings"
                 Stroke="#F59E0B" StrokeThickness="4" Fill="Transparent"
                 StrokeDashArray="0,408" StrokeDashOffset="-1"
                 RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="-90"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="⚙" FontSize="22" Foreground="#F59E0B" HorizontalAlignment="Center"/>
                    <TextBlock Text="Settings" FontSize="11" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Row 3: Exit (right) -->
            <Grid x:Name="Btn_Exit"
                  Grid.Row="2" Grid.Column="2"
                  HorizontalAlignment="Left"
                  Margin="200,-80,0,0"
                  Width="150" Height="150"
                  Cursor="Hand" Tag="Exit">
                <Ellipse x:Name="Glow_Exit" Fill="#00EF4444" Opacity="0"/>
                <Ellipse Stroke="#EF4444" StrokeThickness="2" Fill="#111827"/>
                <Ellipse x:Name="Progress_Exit"
                 Stroke="#EF4444" StrokeThickness="4" Fill="Transparent"
                 StrokeDashArray="0,408" StrokeDashOffset="-1"
                 RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="-90"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="✕" FontSize="22" Foreground="#EF4444" HorizontalAlignment="Center"/>
                    <TextBlock Text="Exit" FontSize="11" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Hand cursor — floats over the grid -->
            <Ellipse x:Name="HandCursor"
             Grid.RowSpan="3" Grid.ColumnSpan="3"
             Width="28" Height="28"
             Fill="#664DD0E1" Stroke="#4DD0E1" StrokeThickness="2"
             Visibility="Collapsed" IsHitTestVisible="False"
             HorizontalAlignment="Left" VerticalAlignment="Top"/>

        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="2"
                   Text="Hover your hand over a button to select  •  Hold to confirm"
                   Foreground="#374151" FontSize="12"
                   HorizontalAlignment="Center" Margin="0,0,0,24"/>
    </Grid>
</Window>