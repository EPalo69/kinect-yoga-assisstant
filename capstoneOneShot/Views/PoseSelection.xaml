<Window x:Class="capstoneOneShot.Views.PoseSelectionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select a Pose" Height="800" Width="1200"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#0A0F1E"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="FilterBtn" TargetType="Button">
            <Setter Property="Background"      Value="#111827"/>
            <Setter Property="Foreground"      Value="#9CA3AF"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="20,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#1F2937"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Skeleton and Menu Canvas Overlays -->
        <Canvas x:Name="SkeletonCanvas" Grid.RowSpan="5" Panel.ZIndex="10" IsHitTestVisible="False"/>
        <Canvas x:Name="MenuCanvas" Grid.RowSpan="5" Panel.ZIndex="20" IsHitTestVisible="False"/>



        <!-- Header -->
        <Border Grid.Row="0" Padding="40,32,40,20">
            <Grid>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="SELECT A POSE"
                               FontSize="32" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Choose a pose to practice"
                               FontSize="14" Foreground="#6B7280"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>


            </Grid>
        </Border>

        <!-- Row 1: ROM profile banner -->
        <Grid Grid.Row="1" Margin="40,0,40,12">
            <Border x:Name="ROMBanner"
                    Background="#0D2137"
                    Padding="16,10"
                    CornerRadius="8"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="✓  " Foreground="#4DD0E1"
                       FontSize="13" FontWeight="Bold"
                       VerticalAlignment="Center"/>
                    <TextBlock x:Name="ROMBannerLabel"
                       Text=""
                       Foreground="#9CA3AF" FontSize="13"
                       VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Grid x:Name="Btn_Back" Width="100" Height="100" Cursor="Hand" Tag="Back"
                      HorizontalAlignment="Center" VerticalAlignment="Center" Margin="400,0,0,0"
                      MouseLeftButtonUp="BackButton_Click" Panel.ZIndex="5">
                <Ellipse x:Name="Glow_Back" Fill="#006B7280" Opacity="0"/>
                <Ellipse Stroke="#6B7280" StrokeThickness="2" Fill="#111827"/>
                <Ellipse x:Name="Progress_Back" Stroke="#6B7280" StrokeThickness="4" Fill="Transparent" StrokeDashArray="0,314" StrokeDashOffset="-1" RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="-90"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="←" FontSize="20" Foreground="#6B7280" HorizontalAlignment="Center"/>
                    <TextBlock Text="Back" FontSize="11" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>


        <!-- Pose cards -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="40,0" VerticalAlignment="Center">
            <ItemsControl x:Name="PoseList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="300" Height="300" Margin="30"
                              Cursor="Hand" Tag="{Binding}"
                              Loaded="PoseCard_Loaded" Unloaded="PoseCard_Unloaded"
                              MouseLeftButtonUp="PoseCard_Click">
                            <Ellipse x:Name="Glow_Pose" Fill="#004DD0E1" Opacity="0"/>
                            <Ellipse Stroke="#4DD0E1" StrokeThickness="2" Fill="#111827"/>
                            <Ellipse x:Name="Progress_Pose" Stroke="#4DD0E1" StrokeThickness="4" Fill="Transparent" StrokeDashArray="0,942" StrokeDashOffset="-1" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform><RotateTransform Angle="-90"/></Ellipse.RenderTransform>
                            </Ellipse>

                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10">
                                <TextBlock Text="{Binding Difficulty}"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="#4DD0E1"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,16"/>
                                <TextBlock Text="{Binding Name}"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="White"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,16"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="⏱ " Foreground="#4DD0E1" FontSize="18"/>
                                    <TextBlock Text="{Binding HoldSeconds, StringFormat={}{0}s hold}"
                                               FontSize="18" Foreground="#9CA3AF"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <TextBlock Grid.Row="3"
                   Text="Hover your hand over a button to select  •  Hold to confirm"
                   Foreground="#374151" FontSize="12"
                   HorizontalAlignment="Center" Margin="0,0,0,24"/>
    </Grid>
</Window>