<Window x:Class="capstoneOneShot.Views.PoseSelectionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select a Pose" Height="800" Width="1200"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#0A0F1E">

    <Window.Resources>
        <Style x:Key="FilterBtn" TargetType="Button">
            <Setter Property="Background"      Value="#111827"/>
            <Setter Property="Foreground"      Value="#9CA3AF"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="20,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#1F2937"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="40,32,40,20">
            <Grid>
                <Button x:Name="BackButton" Content="← Back"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Background="Transparent" Foreground="#6B7280"
                        FontSize="14" BorderThickness="0" Cursor="Hand"
                        Click="BackButton_Click"/>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="SELECT A POSE"
                               FontSize="32" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Choose a pose to practice"
                               FontSize="14" Foreground="#6B7280"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ROM profile banner — shows when ROM test has been completed -->
        <Border x:Name="ROMBanner"
        Grid.Row="1"
        Background="#0D2137"
        Padding="16,10"
        Margin="40,0,40,12"
        CornerRadius="8"
        Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="✓  " Foreground="#4DD0E1"
                   FontSize="13" FontWeight="Bold"
                   VerticalAlignment="Center"/>
                <TextBlock x:Name="ROMBannerLabel"
                   Text=""
                   Foreground="#9CA3AF" FontSize="13"
                   VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Difficulty filter -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,0,0,24">
            <Button x:Name="FilterAll"          Content="All"
                    Tag="All"          Style="{StaticResource FilterBtn}"
                    Click="Filter_Click"/>
            <Button x:Name="FilterBeginner"     Content="Beginner"
                    Tag="Beginner"     Style="{StaticResource FilterBtn}"
                    Click="Filter_Click" Margin="12,0,0,0"/>
            <Button x:Name="FilterIntermediate" Content="Intermediate"
                    Tag="Intermediate" Style="{StaticResource FilterBtn}"
                    Click="Filter_Click" Margin="12,0,0,0"/>
            <Button x:Name="FilterAdvanced"     Content="Advanced"
                    Tag="Advanced"     Style="{StaticResource FilterBtn}"
                    Click="Filter_Click" Margin="12,0,0,0"/>
        </StackPanel>

        <!-- Pose cards -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="40,0">
            <ItemsControl x:Name="PoseList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="260" Height="200" Margin="12"
                                Background="#111827" CornerRadius="12"
                                Cursor="Hand" Tag="{Binding}"
                                MouseLeftButtonUp="PoseCard_Click">
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Difficulty badge -->
                                <Border Grid.Row="0" Background="#1F2937"
                                        CornerRadius="20" Padding="10,4"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Difficulty}"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="#4DD0E1"/>
                                </Border>

                                <!-- Name + description -->
                                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="White"
                                               TextWrapping="Wrap"
                                               Margin="0,12,0,6"/>
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="12" Foreground="#6B7280"
                                               TextWrapping="Wrap" MaxHeight="48"/>
                                </StackPanel>

                                <!-- Hold time -->
                                <StackPanel Grid.Row="2" Orientation="Horizontal">
                                    <TextBlock Text="⏱ " Foreground="#4DD0E1" FontSize="12"/>
                                    <TextBlock Text="{Binding HoldSeconds, StringFormat={}{0}s hold}"
                                               FontSize="12" Foreground="#9CA3AF"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <TextBlock Grid.Row="3"
                   Text="Click a pose to view details and begin"
                   Foreground="#374151" FontSize="12"
                   HorizontalAlignment="Center" Margin="0,12,0,24"/>
    </Grid>
</Window>