<Window x:Class="capstoneOneShot.Views.SessionResultsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Session Results" Height="800" Width="1200"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#0A0F1E"
        WindowStyle="None"
        AllowsTransparency="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <!-- Results content -->
            <RowDefinition Height="Auto"/>
            <!-- Action buttons -->
        </Grid.RowDefinitions>

        <!-- Results -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center"
                    VerticalAlignment="Center" MaxWidth="600">

            <!-- Trophy / result icon -->
            <TextBlock x:Name="ResultIcon" Text="🏆"
                       FontSize="80" HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>

            <TextBlock Text="SESSION COMPLETE"
                       FontSize="14" FontWeight="Bold"
                       Foreground="#4DD0E1"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>

            <TextBlock x:Name="PoseNameLabel"
                       Text="Mountain Pose"
                       FontSize="36" FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,32"/>

            <!-- Score ring -->
            <Border Background="#111827" CornerRadius="100"
                    Width="200" Height="200"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,32">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="AccuracyLabel"
                               Text="0%"
                               FontSize="52" FontWeight="Bold"
                               Foreground="#4DD0E1"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="ACCURACY"
                               FontSize="12" FontWeight="Bold"
                               Foreground="#6B7280"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Stats row -->
            <!-- Stats row -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#111827"
            CornerRadius="10" Padding="16" Margin="0,0,6,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="SESSION TIME" FontSize="10"
                       FontWeight="Bold" Foreground="#6B7280"
                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock x:Name="TotalTimeLabel"
                       Text="00:00" FontSize="24" FontWeight="Bold"
                       Foreground="#22C55E"
                       HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#111827"
            CornerRadius="10" Padding="16" Margin="6,0,6,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="HOLD TIME" FontSize="10"
                       FontWeight="Bold" Foreground="#6B7280"
                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock x:Name="HoldTimeLabel"
                       Text="0s" FontSize="24" FontWeight="Bold"
                       Foreground="#22C55E"
                       HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#111827"
            CornerRadius="10" Padding="16" Margin="6,0,6,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="BEST SCORE" FontSize="10"
                       FontWeight="Bold" Foreground="#6B7280"
                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock x:Name="BestScoreLabel"
                       Text="0%" FontSize="24" FontWeight="Bold"
                       Foreground="#F59E0B"
                       HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="#111827"
            CornerRadius="10" Padding="16" Margin="6,0,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="DIFFICULTY" FontSize="10"
                       FontWeight="Bold" Foreground="#6B7280"
                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock x:Name="DifficultyLabel"
                       Text="Beginner" FontSize="18" FontWeight="Bold"
                       Foreground="#A855F7"
                       HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Feedback message -->
            <Border Background="#111827" CornerRadius="10"
                    Padding="20,14" Margin="0,0,0,0">
                <TextBlock x:Name="FeedbackMessage"
                           Text="Great job! Keep practicing to improve your form."
                           FontSize="14" Foreground="#D1D5DB"
                           TextAlignment="Center" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <!-- Action buttons -->
        <Grid Grid.Row="1" Margin="40,0,40,40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Practice Again -->
            <Button Grid.Column="0" x:Name="PracticeAgainButton"
                    Content="↺  Practice Again"
                    Margin="0,0,8,0" Padding="0,16"
                    FontSize="15" FontWeight="SemiBold"
                    Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="PracticeAgain_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#4DD0E1" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- New Pose -->
            <Button Grid.Column="1" x:Name="NewPoseButton"
                    Content="✦  New Pose"
                    Margin="8,0,8,0" Padding="0,16"
                    FontSize="15" FontWeight="SemiBold"
                    Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="NewPose_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#A855F7" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Main Menu -->
            <Button Grid.Column="2" x:Name="MainMenuButton"
                    Content="⌂  Main Menu"
                    Margin="8,0,0,0" Padding="0,16"
                    FontSize="15" FontWeight="SemiBold"
                    Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="MainMenu_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#1F2937" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>