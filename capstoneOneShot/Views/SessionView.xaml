<Window x:Class="capstoneOneShot.Views.SessionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Yoga Session" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen" Background="#080C14"
        WindowState="Maximized"
        WindowStyle="None"
        AllowsTransparency="True">
    

    <Window.Resources>
        <Style x:Key="FeedbackItem" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF6B6B"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#9E9E9E"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <!-- Top bar -->
            <RowDefinition Height="*"/>
            <!-- Main -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════
             TOP BAR
        ══════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#0D1020"
                BorderBrush="#194DD0E1"
                BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <TextBlock Text="YOGA SESSION"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="#4DD0E1"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════
             MAIN: Camera fills entire width (no sidebar)
        ══════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#050810"
                ClipToBounds="True">
            <Grid>
                <!-- Layer 1: Camera feed -->
                <Image x:Name="CameraFeed" Stretch="Uniform"/>

                <!-- Layer 2: Skeleton overlay -->
                <Canvas x:Name="SkeletonCanvas"/>

                <!-- Layer 2.5: Pause gesture canvas -->
                <Canvas x:Name="PauseGestureCanvas" IsHitTestVisible="True"/>

                <!-- Layer 3: No body detected — full overlay -->
                <Border x:Name="NoBodyOverlay" Background="#CC1A1A2E" Visibility="Visible">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Background="#FFCC00" CornerRadius="50"
                                Width="80" Height="80" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="⚠" FontSize="40" Foreground="#1A1A2E"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="NoBodyTitle" Text="No Body Detected"
                                   FontSize="24" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="Step in front of the Kinect so your full body is visible."
                                   FontSize="14" Foreground="#BDBDBD" TextAlignment="Center"
                                   TextWrapping="Wrap" MaxWidth="400" Margin="0,0,0,24"
                                   HorizontalAlignment="Center"/>
                        <Border Background="#22FFFFFF" CornerRadius="8" Padding="20,16" MaxWidth="420">
                            <StackPanel>
                                <TextBlock Text="TIPS" FontSize="11" FontWeight="Bold"
                                           Foreground="#FFCC00" Margin="0,0,0,10"/>
                                <TextBlock Text="• Stand 1.5 – 2.5 meters from the sensor"
                                           Foreground="#BDBDBD" FontSize="13" Margin="0,0,0,6"/>
                                <TextBlock Text="• Make sure the room is well lit"
                                           Foreground="#BDBDBD" FontSize="13" Margin="0,0,0,6"/>
                                <TextBlock Text="• Full body from head to feet must be visible"
                                           Foreground="#BDBDBD" FontSize="13" Margin="0,0,0,6"/>
                                <TextBlock Text="• Remove objects blocking the sensor"
                                           Foreground="#BDBDBD" FontSize="13"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Layer 4: Partial tracking banner -->
                <Border x:Name="PartialBodyBanner" Background="#EEF59E0B"
                        Padding="16,10" VerticalAlignment="Top" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="⚠  " Foreground="#1A1A2E" FontSize="16"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="Partial tracking — step back so your full body is visible"
                                   Foreground="#1A1A2E" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- HUD: pose name top-left -->
                <Border Background="#AA000000" CornerRadius="8" Padding="12,8"
                        HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="NOW: " Foreground="#9E9E9E" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock x:Name="CurrentPoseLabel" Text="—" Foreground="White"
                                   FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- HUD: TIMERS -->
                <Border Background="#AA000000" CornerRadius="8" Padding="12,8"
                    HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16,60,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="SESSION TIME  " Foreground="#9E9E9E" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock x:Name="SessionTimerLabel" Text="00:00" Foreground="#4CAF50"
                        FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <Border Background="#AA000000" CornerRadius="8" Padding="12,8"
                    HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16,110,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="HELD POSE TIME  " Foreground="#9E9E9E" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock x:Name="HoldTimerLabel" Text="0s" Foreground="#4CAF50"
                                FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                </Border>

                <!-- ═══ HUD: CURRENT INSTRUCTION — top center overlay ═══ -->
                <Border x:Name="InstructionOverlay"
                        Background="#E0101622"
                        BorderBrush="#334DD0E1"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24,14"
                        MinWidth="320"
                        MaxWidth="600"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,16,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <!-- Header row -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                            <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets"
                                       Foreground="#64B5F6" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="INSTRUCTION"
                                       FontFamily="Segoe UI" FontWeight="Bold" FontSize="11"
                                       Foreground="#64B5F6" VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- Current instruction text -->
                        <TextBlock x:Name="CurrentInstructionLabel"
                                   Text=""
                                   FontFamily="Segoe UI"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#E8EDF2"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        <!-- Correction text (shown when a correction is active) -->
                        <Border x:Name="CorrectionBanner"
                                Background="#3E1010"
                                CornerRadius="6"
                                Padding="12,6"
                                Margin="0,8,0,0"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets"
                                           Foreground="#FF6B6B" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock x:Name="CorrectionLabel"
                                           Text=""
                                           FontFamily="Segoe UI" FontSize="13"
                                           Foreground="#FFCDD2"
                                           TextWrapping="Wrap"
                                           MaxWidth="500"/>
                            </StackPanel>
                        </Border>
                        <!-- All done banner -->
                        <Border x:Name="AllDoneBanner" Visibility="Collapsed"
                                Background="#0D2818" CornerRadius="6"
                                Padding="12,8" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                                           Foreground="#4CAF50" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text=" Pose achieved! Hold it."
                                           FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="13"
                                           Foreground="#A5D6A7" Margin="6,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Hidden items controls kept for code-behind data binding -->
                <ItemsControl x:Name="InstructionsList" Visibility="Collapsed"/>
                <ItemsControl x:Name="CorrectionsList" Visibility="Collapsed"/>
                <TextBlock x:Name="AllGoodLabel" Visibility="Collapsed"/>
                <ItemsControl x:Name="FeedbackList" Visibility="Collapsed"/>

                <!-- Hidden elements for code-behind references (corrections/guidance) -->
                <Border x:Name="CorrectionsSection" Visibility="Collapsed"/>
                <Border x:Name="GuidanceDivider" Visibility="Collapsed"/>
                <Border x:Name="GuidancePanel" Visibility="Collapsed"/>

                <!-- ═══ POSE REFERENCE IMAGE — transparent box overlay (bottom-right) ═══ -->
                <Border Background="#D9080C14"
                        BorderBrush="#334DD0E1"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="12"
                        Width="200"
                        Height="240"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,20,20">
                    <Grid>
                        <!-- Label at top -->
                        <TextBlock Text="POSE REFERENCE"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="#9E9E9E"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Top"
                                   Margin="0,2,0,0"/>
                        <!-- Placeholder shown when no image is loaded -->
                        <StackPanel x:Name="PoseImagePlaceholder"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="🧘" FontSize="48"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="No image available"
                                       Foreground="#555577" FontSize="12"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                        <!-- Actual pose reference image (set in code-behind) -->
                        <Image x:Name="PoseReferenceImage"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,20,0,0"
                               Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <!-- PAUSE OVERLAY -->
                <Border x:Name="PauseOverlay"
                        Background="#E0080C14"
                        Visibility="Collapsed">
                    <Border.Effect>
                        <BlurEffect Radius="0"/>
                    </Border.Effect>
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Pause card -->
                        <Canvas x:Name="PauseOverlayCursorCanvas"
                            IsHitTestVisible="False"
                            Panel.ZIndex="9999"/>
                        <Border Background="#F0101622"
                                BorderBrush="#334DD0E1"
                                BorderThickness="1"
                                CornerRadius="20"
                                Padding="48,40"
                                MinWidth="600">
                            <StackPanel HorizontalAlignment="Center">
                                <!-- Pause icon -->
                                <Border Width="56" Height="56"
                                        CornerRadius="28"
                                        Background="#1A4DD0E1"
                                        BorderBrush="#4D4DD0E1"
                                        BorderThickness="1.5"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,18">
                                    <TextBlock Text="⏸" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="PAUSED" FontSize="32" FontWeight="Bold" Foreground="#E8EDF2" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="Your session is paused." FontSize="13" Foreground="#6B7A8D" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,28"/>
                                <!-- Actions -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,10">
                                    <!-- Continue Button -->
                                    <Grid x:Name="ResumeButton" Width="160" Height="160" Margin="15,0" Cursor="Hand" MouseLeftButtonUp="ResumeButton_Click">
                                        <Ellipse Stroke="#4DD0E1" StrokeThickness="2" Fill="#111827"/>
                                        <Ellipse x:Name="Progress_Resume" Stroke="#4DD0E1" StrokeThickness="4" Fill="Transparent" StrokeDashArray="0,502" StrokeDashOffset="-1" RenderTransformOrigin="0.5,0.5">
                                            <Ellipse.RenderTransform><RotateTransform Angle="-90"/></Ellipse.RenderTransform>
                                        </Ellipse>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="▶" FontSize="36" Foreground="#4DD0E1" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                            <TextBlock Text="Continue" FontSize="16" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                    <!-- Back to Selection Button -->
                                    <Grid x:Name="SelectionButton" Width="160" Height="160" Margin="15,0" Cursor="Hand" MouseLeftButtonUp="SelectionButton_Click">
                                        <Ellipse Stroke="#6B7280" StrokeThickness="2" Fill="#111827"/>
                                        <Ellipse x:Name="Progress_Selection" Stroke="#6B7280" StrokeThickness="4" Fill="Transparent" StrokeDashArray="0,502" StrokeDashOffset="-1" RenderTransformOrigin="0.5,0.5">
                                            <Ellipse.RenderTransform><RotateTransform Angle="-90"/></Ellipse.RenderTransform>
                                        </Ellipse>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="↩" FontSize="42" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                            <TextBlock Text="Pose Select" FontSize="16" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                    <!-- Back to Main Menu Button -->
                                    <Grid x:Name="EndSessionButton" Width="160" Height="160" Margin="15,0" Cursor="Hand" MouseLeftButtonUp="EndSessionButton_Click">
                                        <Ellipse Stroke="#EF4444" StrokeThickness="2" Fill="#111827"/>
                                        <Ellipse x:Name="Progress_EndSession" Stroke="#EF4444" StrokeThickness="4" Fill="Transparent" StrokeDashArray="0,502" StrokeDashOffset="-1" RenderTransformOrigin="0.5,0.5">
                                            <Ellipse.RenderTransform><RotateTransform Angle="-90"/></Ellipse.RenderTransform>
                                        </Ellipse>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="✕" FontSize="36" Foreground="#EF4444" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                            <TextBlock Text="Main Menu" FontSize="16" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                                <!-- Gesture hint -->
                                <Border BorderBrush="#0FFFFFFF" BorderThickness="0,1,0,0" Margin="0,22,0,0" Padding="0,18,0,0">
                                    <TextBlock Text="✕  Cross arms again to resume" FontSize="11" Foreground="#3D4A5A" HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>