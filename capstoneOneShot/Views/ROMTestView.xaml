<Window x:Class="capstoneOneShot.Views.ROMTestView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Range of Motion Test"
        Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E">

    <Window.Resources>
        <!-- Base button style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"    Value="#4CAF50"/>
            <Setter Property="Foreground"    Value="White"/>
            <Setter Property="FontSize"      Value="16"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="Padding"       Value="30,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Progress -->
            <RowDefinition Height="*"/>
            <!-- Main content -->
            <RowDefinition Height="Auto"/>
            <!-- Footer button -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Range of Motion Test"
                       FontSize="28" FontWeight="Bold"
                       Foreground="#E0E0E0"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="We'll measure your flexibility to set the right difficulty level for you."
                       FontSize="14" Foreground="#9E9E9E"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>
        </StackPanel>

        <!-- ── Progress bar ── -->
        <StackPanel Grid.Row="1" Margin="0,0,0,32">
            <TextBlock x:Name="ProgressLabel"
                       Text="Test 1 of 4"
                       Foreground="#9E9E9E"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>
            <ProgressBar x:Name="ProgressBar"
                         Minimum="0" Maximum="4" Value="1"
                         Height="8"
                         Foreground="#4CAF50"
                         Background="#333355"
                         BorderThickness="0"/>
        </StackPanel>

        <!-- ── Main content area ── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Skeleton canvas -->
                <ColumnDefinition Width="300"/>
                <!-- Instructions panel -->
            </Grid.ColumnDefinitions>

            <!-- Skeleton / Camera feed -->
            <Border Grid.Column="0"
                    Background="#0D0D1A"
                    CornerRadius="12"
                    Margin="0,0,16,0">
                <Grid>
                    <!-- Skeleton drawing canvas -->
                    <Canvas x:Name="SkeletonCanvas"
                            Width="480" Height="400"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                    <!-- Countdown overlay -->
                    <Border Background="#AA000000"
                            CornerRadius="50"
                            Width="100" Height="100"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,20"
                            x:Name="CountdownBorder">
                        <TextBlock x:Name="CountdownText"
                                   Text="5"
                                   FontSize="48"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Instructions panel -->
            <Border Grid.Column="1"
                    Background="#16213E"
                    CornerRadius="12"
                    Padding="24">
                <StackPanel VerticalAlignment="Center">

                    <TextBlock Text="CURRENT TEST"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#4CAF50"
                               Margin="0,0,0,8"/>

                    <TextBlock x:Name="TestNameLabel"
                               Text="Shoulder Raise"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#E0E0E0"
                               TextWrapping="Wrap"
                               Margin="0,0,0,20"/>

                    <Separator Background="#333355" Margin="0,0,0,20"/>

                    <TextBlock Text="INSTRUCTIONS"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#9E9E9E"
                               Margin="0,0,0,8"/>

                    <TextBlock x:Name="InstructionLabel"
                               Text="Slowly raise both arms as high as you can overhead and hold."
                               FontSize="15"
                               Foreground="#BDBDBD"
                               TextWrapping="Wrap"
                               LineHeight="24"
                               Margin="0,0,0,32"/>

                    <!-- Live angle readout -->
                    <Border Background="#0D0D1A"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="MEASURED ANGLE"
                                       FontSize="11"
                                       Foreground="#9E9E9E"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="AngleReadout"
                                       Text="-- °"
                                       FontSize="36"
                                       FontWeight="Bold"
                                       Foreground="#4CAF50"/>
                        </StackPanel>
                    </Border>

                    <!-- Best angle recorded -->
                    <Border Background="#0D0D1A"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="BEST SO FAR"
                                       FontSize="11"
                                       Foreground="#9E9E9E"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="BestAngleReadout"
                                       Text="-- °"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#FFC107"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Footer button ── -->
        <Button Grid.Row="3"
                x:Name="NextButton"
                Content="Start Test"
                Style="{StaticResource PrimaryButton}"
                HorizontalAlignment="Center"
                Margin="0,24,0,0"
                Click="NextButton_Click"/>

    </Grid>
</Window>
