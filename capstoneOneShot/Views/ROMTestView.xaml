<Window x:Class="capstoneOneShot.Views.ROMTestView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Range of Motion Test" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#1A1A2E"
        WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="30,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Progress -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Button -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Range of Motion Test" FontSize="26" FontWeight="Bold"
                       Foreground="#E0E0E0" HorizontalAlignment="Center"/>
            <TextBlock Text="We'll measure your flexibility to set the right difficulty level."
                       FontSize="13" Foreground="#9E9E9E"
                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Progress -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock x:Name="ProgressLabel" Text="Test 1 of 4"
                       Foreground="#9E9E9E" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
            <ProgressBar x:Name="ProgressBar" Minimum="0" Maximum="4" Value="1"
                         Height="8" Foreground="#4CAF50" Background="#333355"
                         BorderThickness="0"/>
        </StackPanel>

        <!-- Main content: camera panel + instructions panel -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Layered camera + skeleton + warnings -->
            <Border Grid.Column="0" Background="#0D0D1A"
                    CornerRadius="12" Margin="0,0,12,0" ClipToBounds="True">
                <Grid>
                    <!-- Layer 1: Camera -->
                    <Image x:Name="CameraFeed" Stretch="UniformToFill"/>

                    <!-- Layer 2: Skeleton -->
                    <Canvas x:Name="SkeletonCanvas"/>

                    <!-- Layer 3: No body overlay -->
                    <Border x:Name="NoBodyOverlay" Background="#CC1A1A2E" Visibility="Visible">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Background="#FFCC00" CornerRadius="50"
                                    Width="70" Height="70"
                                    HorizontalAlignment="Center" Margin="0,0,0,14">
                                <TextBlock Text="⚠" FontSize="34" Foreground="#1A1A2E"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="No Body Detected" FontSize="20" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Step in front of the Kinect so your full body is visible."
                                       FontSize="13" Foreground="#BDBDBD" TextAlignment="Center"
                                       TextWrapping="Wrap" MaxWidth="340"
                                       HorizontalAlignment="Center" Margin="0,0,0,20"/>
                            <Border Background="#22FFFFFF" CornerRadius="8"
                                    Padding="16,12" MaxWidth="360">
                                <StackPanel>
                                    <TextBlock Text="TIPS" FontSize="11" FontWeight="Bold"
                                               Foreground="#FFCC00" Margin="0,0,0,8"/>
                                    <TextBlock Text="• Stand 1.5 – 2.5 meters from the sensor"
                                               Foreground="#BDBDBD" FontSize="12" Margin="0,0,0,4"/>
                                    <TextBlock Text="• Make sure the room is well lit"
                                               Foreground="#BDBDBD" FontSize="12" Margin="0,0,0,4"/>
                                    <TextBlock Text="• Full body from head to feet must be visible"
                                               Foreground="#BDBDBD" FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Layer 4: Partial tracking banner -->
                    <Border x:Name="PartialBodyBanner" Background="#EEF59E0B"
                            Padding="14,8" VerticalAlignment="Top" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="⚠  " Foreground="#1A1A2E" FontSize="15"
                                       FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Text="Partial tracking — step back so your full body is visible"
                                       Foreground="#1A1A2E" FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Countdown circle (bottom center) -->
                    <Border x:Name="CountdownBorder" Background="#AA000000" CornerRadius="50"
                            Width="90" Height="90"
                            HorizontalAlignment="Center" VerticalAlignment="Bottom"
                            Margin="0,0,0,20">
                        <TextBlock x:Name="CountdownText" Text="5" FontSize="42"
                                   FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- RIGHT: Instructions + readouts -->
            <Border Grid.Column="1" Background="#16213E" CornerRadius="12" Padding="20">
                <StackPanel VerticalAlignment="Center">

                    <TextBlock Text="CURRENT TEST" FontSize="11" FontWeight="Bold"
                               Foreground="#4CAF50" Margin="0,0,0,6"/>
                    <TextBlock x:Name="TestNameLabel" Text="Shoulder Raise"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#E0E0E0" TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <Separator Background="#333355" Margin="0,0,0,16"/>

                    <TextBlock Text="INSTRUCTIONS" FontSize="11" FontWeight="Bold"
                               Foreground="#9E9E9E" Margin="0,0,0,6"/>
                    <TextBlock x:Name="InstructionLabel"
                               Text="Slowly raise both arms as high as you can overhead and hold."
                               FontSize="13" Foreground="#BDBDBD"
                               TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,20"/>

                    <Separator Background="#333355" Margin="0,0,0,16"/>

                    <!-- Tracking status -->
                    <TextBlock Text="TRACKING" FontSize="11" FontWeight="Bold"
                               Foreground="#9E9E9E" Margin="0,0,0,6"/>
                    <Border Background="#0D0D1A" CornerRadius="6" Padding="10,6"
                            Margin="0,0,0,16" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="TrackingDot" Width="10" Height="10"
                                     Fill="#9E9E9E" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TrackingStatusLabel" Text="Waiting..."
                                       Foreground="#9E9E9E" FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <Separator Background="#333355" Margin="0,0,0,16"/>

                    <!-- Live angle -->
                    <Border Background="#0D0D1A" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="MEASURED ANGLE" FontSize="11"
                                       Foreground="#9E9E9E" Margin="0,0,0,4"/>
                            <TextBlock x:Name="AngleReadout" Text="-- °"
                                       FontSize="34" FontWeight="Bold" Foreground="#4CAF50"/>
                        </StackPanel>
                    </Border>

                    <!-- Best angle -->
                    <Border Background="#0D0D1A" CornerRadius="8" Padding="14">
                        <StackPanel>
                            <TextBlock Text="BEST SO FAR" FontSize="11"
                                       Foreground="#9E9E9E" Margin="0,0,0,4"/>
                            <TextBlock x:Name="BestAngleReadout" Text="-- °"
                                       FontSize="26" FontWeight="Bold" Foreground="#FFC107"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>
        </Grid>

        <!-- Footer button -->
        <Button Grid.Row="3" x:Name="NextButton" Content="Start Test"
                Style="{StaticResource PrimaryButton}"
                HorizontalAlignment="Center" Margin="0,16,0,0"
                Click="NextButton_Click"/>
    </Grid>
</Window>